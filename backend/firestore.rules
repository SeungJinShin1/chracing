rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection: client read-only, server (Admin SDK) write-only
    match /users/{uid} {
      allow read: if true;
      allow write: if false;
    }
    // Records collection: client read-only, server (Admin SDK) write-only
    match /records/{recordId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
